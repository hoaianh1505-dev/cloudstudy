        <button class="btn btn-outline-secondary rounded-circle border-0 me-2 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;" onclick="toggleTheme()" title="Đổi giao diện Sáng/Tối">
          <i class="bi bi-moon-stars-fill themeToggleIconClass"></i>
        </button>

        <% if (user) { %>
