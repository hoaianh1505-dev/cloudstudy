  <% if (typeof user !== 'undefined' && user) { %>
    <!-- Floating AI Assistant Bubble -->
    <button class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center" id="aiChatBubble" onclick="toggleAiChat()" style="position: fixed; bottom: 100px; right: 30px; width: 56px; height: 56px; z-index: 1000; border: none; background: linear-gradient(135deg, #6366f1, #a855f7); color: white; box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3) !important;">
      <i class="bi bi-robot fs-3"></i>
    </button>

    <!-- AI Chat Box Window -->
    <div class="card glass-panel shadow-lg d-none border-0 rounded-4" id="aiChatWindow" style="position: fixed; bottom: 170px; right: 30px; width: 350px; height: 450px; z-index: 1000; overflow: hidden; display: flex; flex-direction: column;">
      <!-- Chat Header -->
      <div class="card-header border-0 d-flex justify-content-between align-items-center py-3" style="background: linear-gradient(to right, #6366f1, #a855f7); color: white;">
        <div class="d-flex align-items-center">
          <i class="bi bi-robot fs-4 me-2"></i>
          <div>
            <h6 class="mb-0 fw-bold">Trợ lý học tập AI</h6>
            <span class="opacity-75" style="font-size: 10px;">Gemini 3.5 Flash</span>
          </div>
        </div>
        <button type="button" class="btn-close btn-close-white" onclick="toggleAiChat()" aria-label="Close"></button>
      </div>
      <!-- Chat Body -->
      <div class="card-body p-3 flex-grow-1 overflow-auto d-flex flex-column gap-2" id="aiChatBody" style="font-size: 13px;">
        <div class="d-flex gap-2 align-items-start mb-2">
          <div class="p-2.5 rounded-3 border bg-light text-dark" style="max-width: 85%;">
            Xin chào <strong><%= user.username %></strong>! Tôi có thể giúp gì cho bạn trong việc học tập và quản lý tài liệu hôm nay?
          </div>
        </div>
      </div>
      <!-- Chat Footer Input -->
      <div class="card-footer border-0 p-3 bg-transparent">
        <form id="aiChatForm" onsubmit="sendAiMessage(event)">
          <div class="input-group">
            <input type="text" id="aiChatInput" class="form-control rounded-start-pill py-2 ps-3" placeholder="Nhập câu hỏi cho AI..." required>
            <button class="btn btn-primary rounded-end-pill px-3" type="submit">
              <i class="bi bi-send-fill"></i>
            </button>
          </div>
        </form>
      </div>
    </div>
  <% } %>

  <!-- Bootstrap Bundle with Popper -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Custom JS -->
  <script src="/js/main.js"></script>
</body>
</html>
