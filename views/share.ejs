<%- include('partials/head') %>

<div class="auth-container flex-column">
  <!-- Small Brand Header -->
  <div class="d-flex align-items-center mb-4">
    <div class="bg-primary text-white rounded-3 p-2 d-flex align-items-center justify-content-center me-2" style="width: 36px; height: 36px;">
      <i class="bi bi-cloud-arrow-up-fill fs-5"></i>
    </div>
    <span class="brand-font fw-bold fs-4 text-primary">CloudStudy</span>
  </div>

  <div class="card auth-card glass-panel p-4 text-center">
    <% if (error) { %>
      <div class="text-center py-4">
        <i class="bi bi-shield-slash-fill display-3 text-danger mb-3"></i>
        <h4 class="fw-bold mb-2">Liên kết đã hết hạn hoặc không tồn tại</h4>
        <p class="text-muted small mb-4"><%= error %></p>
        <a href="/login" class="btn btn-primary px-4 py-2">Đi đến Đăng nhập</a>
      </div>
    <% } else { %>
      <!-- File Shared Details -->
      <div class="mb-4">
        <% if (isImage) { %>
          <div class="preview-img-container border rounded overflow-hidden shadow-sm mb-3 mx-auto" style="max-width: 320px; max-height: 200px;">
            <img src="/share/<%= token %>/download" class="img-fluid" style="object-fit: contain; max-height: 200px;" alt="<%= doc.fileName %>">
          </div>
        <% } else { %>
          <% 
            let iconClass = 'bi-file-earmark-text';
            let badgeColor = 'bg-secondary';
            let docExt = doc.fileName.split('.').pop().toLowerCase();
            if (docExt === 'pdf') { iconClass = 'bi-file-earmark-pdf-fill text-danger'; badgeColor = 'bg-pdf'; }
            else if (['doc', 'docx'].includes(docExt)) { iconClass = 'bi-file-earmark-word-fill text-primary'; badgeColor = 'bg-docx'; }
            else if (['ppt', 'pptx'].includes(docExt)) { iconClass = 'bi-file-earmark-slides-fill text-warning'; badgeColor = 'bg-pptx'; }
            else if (['xls', 'xlsx'].includes(docExt)) { iconClass = 'bi-file-earmark-excel-fill text-success'; badgeColor = 'bg-xlsx'; }
            else if (docExt === 'zip') { iconClass = 'bi-file-earmark-zip-fill text-secondary'; badgeColor = 'bg-zip'; }
          %>
          <i class="bi <%= iconClass %> display-2 mb-3 text-muted"></i>
          <br>
          <span class="file-badge <%= badgeColor %> mb-3 px-3 py-1 text-uppercase small"><%= docExt %></span>
        <% } %>
        
        <h4 class="fw-bold text-wrap text-break mt-2 mb-1" style="max-width: 100%;"><%= doc.fileName %></h4>
        <p class="text-muted small mb-3">Dung lượng: <%= formatBytes(doc.fileSize) %></p>
      </div>

      <div class="bg-light p-3 rounded-3 mb-4 text-start small border">
        <div class="d-flex justify-content-between mb-1">
          <span class="text-muted fw-semibold">Loại tài liệu:</span>
          <code><%= doc.fileType %></code>
        </div>
        <div class="d-flex justify-content-between">
          <span class="text-muted fw-semibold">Ngày tải lên:</span>
          <span><%= new Date(doc.uploadedAt).toLocaleDateString('vi-VN') %></span>
        </div>
      </div>

      <!-- Action -->
      <a href="/share/<%= token %>/download" class="btn btn-primary btn-lg w-100 py-2.5 mb-3">
        <i class="bi bi-cloud-arrow-down-fill me-2"></i> Tải tài liệu (Miễn phí)
      </a>

      <!-- CTA to Register -->
      <div class="pt-3 border-top mt-2">
        <p class="text-muted small mb-0">Bạn cũng muốn lưu trữ và chia sẻ tài liệu?<br><a href="/register" class="fw-semibold text-primary text-decoration-none">Đăng ký tài khoản CloudStudy ngay</a></p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
