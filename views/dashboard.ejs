<%- include('partials/head') %>

<div class="d-flex flex-column flex-lg-row">
  <!-- Sidebar -->
  <%- include('partials/sidebar') %>

  <!-- Main Content Area -->
  <main class="main-content flex-grow-1">
    <!-- Top Navbar -->
    <%- include('partials/navbar') %>

    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
      <div>
        <h2 class="fw-bold mb-1">Hệ thống Quản lý Tài liệu</h2>
        <p class="text-muted mb-0">Xin chào, <strong><%= user.username %></strong>! Chúc bạn học tập hiệu quả hôm nay.</p>
      </div>
      <div class="mt-3 mt-md-0 d-flex gap-2">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadFileModal">
          <i class="bi bi-plus-circle me-1"></i> Tải tài liệu
        </button>
      </div>
    </div>

    <!-- Alert Notifications if any -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4" role="alert">
        <i class="bi bi-x-circle-fill me-2"></i><%= error %>
      </div>
    <% } %>

    <!-- Metric Dashboard Cards -->
    <div class="row g-4 mb-4">
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card premium-card p-3 d-flex flex-row align-items-center">
          <div class="rounded-3 bg-warning bg-opacity-10 p-3 me-3 text-warning fs-3">
            <i class="bi bi-folder-fill"></i>
          </div>
          <div>
            <h6 class="text-muted text-uppercase fw-semibold mb-0" style="font-size: 11px;">Thư mục</h6>
            <h3 class="fw-bold mb-0"><%= totalFolders %></h3>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card premium-card p-3 d-flex flex-row align-items-center">
          <div class="rounded-3 bg-primary bg-opacity-10 p-3 me-3 text-primary fs-3">
            <i class="bi bi-file-earmark-text-fill"></i>
          </div>
          <div>
            <h6 class="text-muted text-uppercase fw-semibold mb-0" style="font-size: 11px;">Tài liệu</h6>
            <h3 class="fw-bold mb-0"><%= totalDocuments %></h3>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card premium-card p-3 d-flex flex-row align-items-center">
          <div class="rounded-3 bg-info bg-opacity-10 p-3 me-3 text-info fs-3">
            <i class="bi bi-image-fill"></i>
          </div>
          <div>
            <h6 class="text-muted text-uppercase fw-semibold mb-0" style="font-size: 11px;">Hình ảnh</h6>
            <h3 class="fw-bold mb-0"><%= totalImages %></h3>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card premium-card p-3 d-flex flex-row align-items-center">
          <div class="rounded-3 bg-success bg-opacity-10 p-3 me-3 text-success fs-3">
            <i class="bi bi-cloud-check-fill"></i>
          </div>
          <div class="flex-grow-1 min-w-0">
            <h6 class="text-muted text-uppercase fw-semibold mb-0" style="font-size: 11px;">Dung lượng Cloud</h6>
            <h3 class="fw-bold mb-0 text-truncate" style="max-width: 140px;" title="<%= totalStorage %>"><%= totalStorage %></h3>
            <% 
              const freeTierLimit = 5 * 1024 * 1024 * 1024; // 5 GB
              const usagePercent = Math.min(((totalStorageBytes / freeTierLimit) * 100), 100).toFixed(2);
            %>
            <div class="mt-2" style="width: 100%;">
              <div class="progress" style="height: 5px; background-color: rgba(0,0,0,0.05); border-radius: 3px;">
                <div class="progress-bar" role="progressbar" style="width: <%= usagePercent %>%; background: linear-gradient(to right, #6366f1, #a855f7); border-radius: 3px;" aria-valuenow="<%= usagePercent %>" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
              <div class="d-flex justify-content-between mt-1" style="font-size: 9px; color: #64748b;">
                <span><%= usagePercent %>% đã dùng</span>
                <span>Max 5 GB</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Workspace Section -->
    <div class="row g-4">
      <!-- Recent Files Table -->
      <div class="col-12">
        <div class="card premium-card p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Tài liệu tải lên gần đây</h5>
            <a href="/folders" class="btn btn-sm btn-link text-decoration-none fw-semibold">Xem tất cả</a>
          </div>
          
          <% if (recentDocuments && recentDocuments.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light border-0">
                  <tr>
                    <th scope="col" class="border-0 rounded-start">Tên tài liệu</th>
                    <th scope="col" class="border-0">Thư mục</th>
                    <th scope="col" class="border-0">Dung lượng</th>
                    <th scope="col" class="border-0">Ngày tải</th>
                    <th scope="col" class="border-0 text-end rounded-end">Thao tác</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentDocuments.forEach(doc => { %>
                    <% 
                      let badgeClass = 'bg-secondary';
                      let docExt = doc.fileName.split('.').pop().toLowerCase();
                      if (docExt === 'pdf') badgeClass = 'bg-pdf';
                      else if (['doc', 'docx'].includes(docExt)) badgeClass = 'bg-docx';
                      else if (['ppt', 'pptx'].includes(docExt)) badgeClass = 'bg-pptx';
                      else if (['xls', 'xlsx'].includes(docExt)) badgeClass = 'bg-xlsx';
                      else if (docExt === 'zip') badgeClass = 'bg-zip';
                      else if (['jpg', 'jpeg', 'png', 'webp'].includes(docExt)) badgeClass = 'bg-image';
                    %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <span class="file-badge <%= badgeClass %> me-2 text-uppercase"><%= docExt %></span>
                          <a href="/document/<%= doc._id %>" class="text-decoration-none text-dark fw-semibold text-truncate" style="max-width: 250px;" title="<%= doc.fileName %>">
                            <%= doc.fileName %>
                          </a>
                        </div>
                      </td>
                      <td>
                        <% if (doc.folderId) { %>
                          <span class="badge bg-light text-dark border"><i class="bi bi-folder2 me-1"></i><%= doc.folderId.name %></span>
                        <% } else { %>
                          <span class="text-muted italic" style="font-size: 13px;">Root</span>
                        <% } %>
                      </td>
                      <td><%= formatBytes(doc.fileSize) %></td>
                      <td><%= new Date(doc.uploadedAt).toLocaleDateString('vi-VN') %></td>
                      <td class="text-end">
                        <div class="btn-group">
                          <a href="/document/<%= doc._id %>" class="btn btn-sm btn-outline-secondary" title="Chi tiết"><i class="bi bi-info-circle"></i></a>
                          <a href="/document/<%= doc._id %>/download" class="btn btn-sm btn-outline-primary" title="Tải xuống"><i class="bi bi-download"></i></a>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="bi bi-file-earmark-arrow-up-fill text-primary mb-3 d-block animate-bounce" style="font-size: 4.5rem; opacity: 0.85;"></i>
              <p class="text-muted mb-0">Bạn chưa tải lên tài liệu học tập nào. Hãy nhấn "Tải file lên" để bắt đầu!</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Floating Action Button for Upload -->
<button class="fab-upload" data-bs-toggle="modal" data-bs-target="#uploadFileModal" title="Tải tài liệu mới">
  <i class="bi bi-plus-lg"></i>
</button>

<%- include('partials/footer') %>
