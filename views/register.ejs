<%- include('partials/head') %>

<div class="auth-container">
  <div class="card auth-card glass-panel p-4">
    <div class="text-center mb-4">
      <div class="bg-primary text-white rounded-3 p-2 d-inline-flex align-items-center justify-content-center mb-2" style="width: 48px; height: 48px;">
        <i class="bi bi-person-plus-fill fs-3"></i>
      </div>
      <h3 class="fw-bold mb-1">Tạo tài khoản mới</h3>
      <p class="text-muted small">Bắt đầu lưu trữ tài liệu học tập của bạn</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger border-0 rounded-3 shadow-sm d-flex align-items-center mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div><%= error %></div>
      </div>
    <% } %>

    <form action="/register" method="POST">
      <div class="mb-3">
        <label for="usernameInput" class="form-label small fw-semibold text-muted">Tên người dùng (Họ tên)</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
          <input type="text" class="form-control border-start-0 bg-light" id="usernameInput" name="username" placeholder="Nguyễn Văn A" required>
        </div>
      </div>

      <div class="mb-3">
        <label for="emailInput" class="form-label small fw-semibold text-muted">Địa chỉ Email</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
          <input type="email" class="form-control border-start-0 bg-light" id="emailInput" name="email" placeholder="name@school.edu.vn" required>
        </div>
      </div>
      
      <div class="mb-4">
        <label for="passwordInput" class="form-label small fw-semibold text-muted">Mật khẩu</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock"></i></span>
          <input type="password" class="form-control border-start-0 bg-light" id="passwordInput" name="password" placeholder="Tối thiểu 6 ký tự" required>
        </div>
      </div>

      <button type="submit" class="btn btn-primary w-100 py-2.5 mb-3">Đăng ký tài khoản</button>
    </form>

    <div class="text-center mt-3">
      <p class="text-muted small mb-0">Đã có tài khoản? <a href="/login" class="fw-semibold text-primary text-decoration-none">Đăng nhập</a></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
