<%- include('partials/head') %>

<div class="d-flex flex-column flex-lg-row">
  <!-- Sidebar -->
  <%- include('partials/sidebar') %>

  <!-- Main Content Area -->
  <main class="main-content flex-grow-1">
    <!-- Top Navbar -->
    <%- include('partials/navbar') %>

    <!-- Page Header & Breadcrumbs -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
      <div>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Tất cả tài liệu (Root)</li>
          </ol>
        </nav>
        <h2 class="fw-bold mb-0">Tài liệu học tập</h2>
      </div>
      <div class="mt-3 mt-md-0 d-flex gap-2">
        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#createFolderModal">
          <i class="bi text-warning bi-folder-plus me-1"></i> Tạo thư mục
        </button>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadFileModal">
          <i class="bi bi-cloud-arrow-up me-1"></i> Tải tài liệu lên
        </button>
      </div>
    </div>

    <!-- Alert Notifications -->
    <% if (error) { %>
      <div class="alert alert-danger border-0 rounded-3 shadow-sm mb-4"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success border-0 rounded-3 shadow-sm mb-4"><%= success %></div>
    <% } %>

    <!-- Folders Directory Grid Section -->
    <div class="mb-5">
      <h5 class="fw-bold mb-3 d-flex align-items-center">
        <i class="bi bi-folder2-open me-2 text-primary"></i> Thư mục
      </h5>
      <% if (subfolders && subfolders.length > 0) { %>
        <div class="row g-3 row-cols-1 row-cols-md-3 row-cols-lg-4">
          <% subfolders.forEach(folder => { %>
            <div class="col">
              <div class="card premium-card p-3 d-flex flex-row align-items-center justify-content-between cursor-pointer" onclick="if(!event.target.closest('.dropdown')){ window.location.href='/folder/<%= folder._id %>'; }">
                <div class="d-flex align-items-center flex-grow-1 text-truncate">
                  <i class="bi bi-folder-fill fs-3 text-warning me-2"></i>
                  <span class="fw-semibold text-truncate" title="<%= folder.name %>"><%= folder.name %></span>
                </div>
                <div class="dropdown">
                  <button class="btn btn-link text-muted p-1" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-three-dots-vertical"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                    <li><a class="dropdown-item py-2" href="#" onclick="renameFolder('<%= folder._id %>', '<%= folder.name %>')"><i class="bi bi-pencil me-2"></i>Đổi tên</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item py-2 text-danger" href="#" onclick="deleteFolder('<%= folder._id %>', '/folders')"><i class="bi bi-trash me-2"></i>Xóa thư mục</a></li>
                  </ul>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="card premium-card p-4 border-dashed text-center">
          <p class="text-muted mb-0 small">Không có thư mục nào ở cấp độ này.</p>
        </div>
      <% } %>
    </div>

    <!-- Documents Section -->
    <div class="mb-4">
      <h5 class="fw-bold mb-3 d-flex align-items-center">
        <i class="bi bi-file-earmark-text me-2 text-primary"></i> Tài liệu & Hình ảnh
      </h5>
      <% if (documents && documents.length > 0) { %>
        <div class="card premium-card p-4">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light border-0">
                <tr>
                  <th scope="col" class="border-0 rounded-start">Tên tài liệu</th>
                  <th scope="col" class="border-0">Kích thước</th>
                  <th scope="col" class="border-0">Ngày tải</th>
                  <th scope="col" class="border-0 text-end rounded-end">Thao tác</th>
                </tr>
              </thead>
              <tbody>
                <% documents.forEach(doc => { %>
                  <% 
                    let badgeClass = 'bg-secondary';
                    let docExt = doc.fileName.split('.').pop().toLowerCase();
                    if (docExt === 'pdf') badgeClass = 'bg-pdf';
                    else if (['doc', 'docx'].includes(docExt)) badgeClass = 'bg-docx';
                    else if (['ppt', 'pptx'].includes(docExt)) badgeClass = 'bg-pptx';
                    else if (['xls', 'xlsx'].includes(docExt)) badgeClass = 'bg-xlsx';
                    else if (docExt === 'zip') badgeClass = 'bg-zip';
                    else if (['jpg', 'jpeg', 'png', 'webp'].includes(docExt)) badgeClass = 'bg-image';
                  %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <span class="file-badge <%= badgeClass %> me-2 text-uppercase"><%= docExt %></span>
                        <a href="/document/<%= doc._id %>" class="text-decoration-none text-dark fw-semibold text-truncate" style="max-width: 320px;" title="<%= doc.fileName %>">
                          <%= doc.fileName %>
                        </a>
                      </div>
                    </td>
                    <td><%= formatBytes(doc.fileSize) %></td>
                    <td><%= new Date(doc.uploadedAt).toLocaleDateString('vi-VN') %></td>
                    <td class="text-end">
                      <div class="btn-group">
                        <a href="/document/<%= doc._id %>" class="btn btn-sm btn-outline-secondary" title="Chi tiết"><i class="bi bi-info-circle"></i></a>
                        <a href="/document/<%= doc._id %>/download" class="btn btn-sm btn-outline-primary" title="Tải xuống"><i class="bi bi-download"></i></a>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteDocument('<%= doc._id %>', '/folders')" title="Xóa"><i class="bi bi-trash"></i></button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } else { %>
        <div class="text-center py-5 glass-panel rounded-4">
          <i class="bi bi-file-earmark-arrow-up-fill text-primary mb-3 d-block" style="font-size: 4.5rem; opacity: 0.85;"></i>
          <p class="text-muted mb-0">Không có tài liệu nào được tải lên ở thư mục gốc.</p>
        </div>
      <% } %>
    </div>
  </main>
</div>

<!-- Floating Action Button for Upload -->
<button class="fab-upload" data-bs-toggle="modal" data-bs-target="#uploadFileModal" title="Tải tài liệu mới">
  <i class="bi bi-plus-lg"></i>
</button>

<%- include('partials/footer') %>
